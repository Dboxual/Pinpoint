# Gradle cache
.gradle/

# Compiled class files and intermediates
bin/
build/classes/
build/resources/
build/reports/
build/tmp/
build/generated/
build/sources.txt
*.class

# Old release jars — only the current release jar is tracked (in build/libs/)
build/libs/Pinpoint-1.3.*.jar

# Dependency jars — managed by Gradle; use ./gradlew build to compile
# If using build.sh instead, download these manually (see build.sh classpath)
libs/*.jar

# Gradle binary wrapper jar (properties file is intentionally tracked)
gradle/wrapper/gradle-wrapper.jar

# IDE
.idea/
*.iml
.vscode/
*.code-workspace

# OS
.DS_Store
Thumbs.db

# Javac arg files
javac.*.args

# Logs
*.log

# General build output
target/
out/
cache/

# Note: build/libs/Pinpoint-<current>.jar is intentionally tracked as a release artifact
# Note: gradlew and gradle/wrapper/gradle-wrapper.properties are intentionally tracked
